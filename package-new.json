{
  // Complete package.json with Vite/React Router - comments on every relevant line
  "name": "sonicsphere", // Changed name from 'nextn' to reflect Vite app
  "version": "0.1.0", // Current version
  "private": true, // Private package
  "scripts": {
    "dev": "vite", // Vite dev server (replaces next dev)
    "build": "tsc && vite build", // TypeScript check + Vite build
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0", // ESLint (updated from next lint)
    "preview": "vite preview", // Vite preview build
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts", // Keep Genkit dev
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts", // Keep Genkit watch
    "typecheck": "tsc --noEmit" // TypeScript check
  },
  "dependencies": {
    // Core React
    "react": "^19.2.1", // React runtime
    "react-dom": "^19.2.1", // React DOM renderer
    
    // Router (NEW - replaces Next.js routing)
    "react-router-dom": "^6.26.2", // React Router for client-side routing
    
    // UI & Styling
    "@radix-ui/react-accordion": "^1.2.3", // Radix primitives
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-menubar": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1", // Tailwind class variants
    "clsx": "^2.1.1", // Conditional CSS classes
    "lucide-react": "^0.475.0", // Icons
    "tailwind-merge": "^3.0.1", // Tailwind class merging
    "tailwindcss-animate": "^1.0.7", // Tailwind animations
    
    // Forms & Validation
    "@hookform/resolvers": "^4.1.3", // Zod resolver for react-hook-form
    "react-hook-form": "^7.54.2", // Form library
    "zod": "^3.24.2", // Schema validation
    
    // Charts
    "recharts": "^2.15.1", // Charts library
    
    // Firebase & Cloud
    "firebase": "^11.9.1", // Firebase SDK
    "cloudinary": "^2.2.0", // Cloudinary uploads
    
    // i18n
    "i18next": "^23.11.5", // i18next core
    "i18next-browser-languagedetector": "^8.0.0", // Language detection
    "react-i18next": "^14.1.2", // React bindings
    
    // AI/Genkit
    "@genkit-ai/google-genai": "^1.28.0", // Google AI integration
    "genkit": "^1.28.0", // Genkit AI framework
    
    // Utils
    "date-fns": "^3.6.0", // Date utilities
    "dotenv": "^16.5.0", // Env vars
    "embla-carousel-react": "^8.6.0", // Carousel
    "jose": "^5.4.1", // JWT utilities
    "patch-package": "^8.0.0", // Patch dependencies
    "react-day-picker": "^9.11.3" // Date picker
  },
  "devDependencies": {
    // TypeScript
    "@types/node": "^20", // Node types
    "@types/react": "^19.2.1", // React types
    "@types/react-dom": "^19.2.1", // React DOM types
    
    // Vite
    "@vitejs/plugin-react-swc": "^3.9.0", // React SWC plugin (already in Vite config)
    "vite": "^6.0.4", // Vite build tool
    "vite-tsconfig-paths": "^5.0.1", // TSConfig paths support
    
    // Tailwind
    "tailwindcss": "^3.4.1", // Tailwind CSS
    "postcss": "^8", // PostCSS
    
    // AI
    "genkit-cli": "^1.28.0", // Genkit CLI
    
    // TypeScript
    "typescript": "^5" // TypeScript compiler
  }
}
